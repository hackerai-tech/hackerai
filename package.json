    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "3.9.3",
    "tailwindcss": "^4.3.2",
    "trigger.dev": "4.5.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
