{
  "default": {
    "identifier": "default",
    "description": "Default capabilities for ZHACKER Desktop",
    "remote": { "urls": ["http://localhost:*", "https://zhacker.ai/*"] },
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      {
        "identifier": "shell:allow-open",
        "allow": [
          { "path": "http://**", "scheme": "http" },
          { "path": "https://**", "scheme": "https" }
        ]
      },
      "allow-desktop-command-bridge",
      "os:default",
      "process:default",
      "updater:default",
      "deep-link:default",
      "dialog:default",
      "opener:default",
      {
        "identifier": "opener:allow-open-path",
        "allow": [
          { "path": "$HOME/**" },
          { "path": "$DOWNLOAD/**" },
          { "path": "/tmp/hackerai-upload/**" },
          { "path": "/tmp/hackerai/**" }
        ]
      }
    ]
  }
}
