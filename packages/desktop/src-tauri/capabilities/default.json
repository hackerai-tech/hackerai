{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for ZHACKER Desktop",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:*", "https://zhacker.ai/*"]
  },
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "path": "http://**", "scheme": "http" },
        { "path": "https://**", "scheme": "https" }
      ]
    },
    "allow-desktop-command-bridge",
    "os:default",
    "process:default",
    "updater:default",
    "deep-link:default",
    "dialog:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "/tmp/hackerai-upload/**" },
        { "path": "/tmp/hackerai/**" }
      ]
    }
  ]
}
